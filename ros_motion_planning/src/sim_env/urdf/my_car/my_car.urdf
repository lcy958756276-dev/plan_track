<?xml version="1.0" encoding="utf-8"?>
<robot name="my_car">
  <!-- ============================================================
       base_footprint — ROS 地面投影坐标系 (X=前, Y=左, Z=上)
       通过 rpy 旋转把 SolidWorks 坐标系映射到 ROS 坐标系
       SW (X=左右, Y=上下, Z=前后)
       ROS (X=前后, Y=左右, Z=上下)
       rpy = (π/2, 0, -π/2) 实现该映射
       ============================================================ -->
  <link name="base_footprint" />

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child  link="base_link" />
    <origin xyz="0 0 0" rpy="1.5708 0 -1.5708" />
  </joint>

  <!-- ============================================================
       base_link — 车身（位置/碰撞用 STL）
       ============================================================ -->
  <link name="base_link">
    <inertial>
      <origin xyz="8.9252E-05 0.040687 0.25548" rpy="0 0 0" />
      <mass value="3.6348" />
      <inertia ixx="0.025881" ixy="1.2305E-06" ixz="2.0103E-05"
               iyy="0.025906" iyz="5.3567E-05" izz="0.0024753" />
    </inertial>
    <visual>
      <origin xyz="0 0.04 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/base_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0.04 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <!-- ============================================================
       左前轮
       ============================================================ -->
  <link name="left_wheel_front_link">
    <inertial>
      <origin xyz="0.0097088 -5.4153E-05 0.00073677" rpy="0 0 0" />
      <mass value="0.82615" />
      <inertia ixx="0.0051911" ixy="-4.7551E-08" ixz="1.0566E-06"
               iyy="0.0028202" iyz="1.1756E-07" izz="0.0028228" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/left_wheel_front_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/left_wheel_front_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_front_joint" type="continuous">
    <parent link="base_link" />
    <child  link="left_wheel_front_link" />
    <origin xyz="-0.104 5.3E-05 0.085" rpy="0 0 0" />
    <axis xyz="1 0 0" />
  </joint>

  <!-- ============================================================
       左后轮
       ============================================================ -->
  <link name="left_wheel_rear_link">
    <inertial>
      <origin xyz="0.0097088 -4.1762E-05 0.00073758" rpy="0 0 0" />
      <mass value="0.82615" />
      <inertia ixx="0.0051911" ixy="-2.9788E-08" ixz="1.0573E-06"
               iyy="0.0028202" iyz="1.6015E-07" izz="0.0028228" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/left_wheel_rear_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/left_wheel_rear_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_rear_joint" type="continuous">
    <parent link="base_link" />
    <child  link="left_wheel_rear_link" />
    <origin xyz="-0.104 4.0E-05 0.421" rpy="0 0 0" />
    <axis xyz="1 0 0" />
  </joint>

  <!-- ============================================================
       右前轮
       ============================================================ -->
  <link name="right_wheel_front_link">
    <inertial>
      <origin xyz="-0.0097088 3.8074E-05 -0.00073778" rpy="0 0 0" />
      <mass value="0.82615" />
      <inertia ixx="0.0051911" ixy="-8.4477E-08" ixz="1.0543E-06"
               iyy="0.0028203" iyz="-4.2774E-07" izz="0.0028227" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/right_wheel_front_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/right_wheel_front_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_front_joint" type="continuous">
    <parent link="base_link" />
    <child  link="right_wheel_front_link" />
    <origin xyz="0.104 -4.1E-05 0.087" rpy="0 0 0" />
    <axis xyz="1 0 0" />
  </joint>

  <!-- ============================================================
       右后轮
       ============================================================ -->
  <link name="right_wheel_rear_link">
    <inertial>
      <origin xyz="-0.0097088 -0.00054882 -0.00049453" rpy="0 0 0" />
      <mass value="0.82615" />
      <inertia ixx="0.0051911" ixy="7.6491E-07" ixz="7.2952E-07"
               iyy="0.0028213" iyz="1.2600E-06" izz="0.0028217" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/right_wheel_rear_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/right_wheel_rear_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_rear_joint" type="continuous">
    <parent link="base_link" />
    <child  link="right_wheel_rear_link" />
    <origin xyz="0.104 0.00056 0.423" rpy="0 0 0" />
    <axis xyz="1 0 0" />
  </joint>

  <!-- ============================================================
       激光雷达 base_scan（frame 名必须与 gazebo_sync.py 一致）
       ============================================================ -->
  <link name="base_scan">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/base_scan.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/base_scan.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="base_scan_joint" type="fixed">
    <parent link="base_link" />
    <child  link="base_scan" />
    <origin xyz="-0.00074 0.187 0.076" rpy="0 0 0" />
  </joint>

  <!-- Gazebo 配置：静态模型（不受重力影响，只由 set_model_state 驱动位置） -->
  <gazebo>
    <static>true</static>
  </gazebo>
</robot>
