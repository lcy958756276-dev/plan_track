<?xml version="1.0" encoding="utf-8"?>
<robot name="my_car">
  <link name="base_footprint" />

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint" />
    <child  link="base_link" />
    <origin xyz="-0.254 0 0.1105" rpy="1.5708 0 -1.5708" />
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="8.9252E-05 -0.019313 0.00148" rpy="0 0 0" />
      <mass value="3.6348" />
      <inertia ixx="0.025881" ixy="1.2305E-06" ixz="2.0103E-05"
               iyy="0.025906" iyz="5.3567E-05" izz="0.0024753" />
    </inertial>
    <visual>
      <origin xyz="0 -0.06 -0.254" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/base_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 -0.06 -0.254" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/base_link.STL" />
      </geometry>
    </collision>
  </link>

  <link name="left_wheel_front_link">
    <inertial>
      <origin xyz="0.0097088 -5.4153E-05 0.00073677" rpy="0 0 0" />
      <mass value="0.82615" />
      <inertia ixx="0.0051911" ixy="-4.7551E-08" ixz="1.0566E-06"
               iyy="0.0028202" iyz="1.1756E-07" izz="0.0028228" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/left_wheel_front_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/left_wheel_front_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_front_joint" type="continuous">
    <parent link="base_link" />
    <child  link="left_wheel_front_link" />
    <origin xyz="-0.104 -0.004 -0.169" rpy="0 0 0" />
    <axis xyz="1 0 0" />
  </joint>

  <link name="left_wheel_rear_link">
    <inertial>
      <origin xyz="0.0097088 -4.1762E-05 0.00073758" rpy="0 0 0" />
      <mass value="0.82615" />
      <inertia ixx="0.0051911" ixy="-2.9788E-08" ixz="1.0573E-06"
               iyy="0.0028202" iyz="1.6015E-07" izz="0.0028228" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/left_wheel_rear_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/left_wheel_rear_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="left_wheel_rear_joint" type="continuous">
    <parent link="base_link" />
    <child  link="left_wheel_rear_link" />
    <origin xyz="-0.104 -0.004 0.167" rpy="0 0 0" />
    <axis xyz="1 0 0" />
  </joint>

  <link name="right_wheel_front_link">
    <inertial>
      <origin xyz="-0.0097088 3.8074E-05 -0.00073778" rpy="0 0 0" />
      <mass value="0.82615" />
      <inertia ixx="0.0051911" ixy="-8.4477E-08" ixz="1.0543E-06"
               iyy="0.0028203" iyz="-4.2774E-07" izz="0.0028227" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/right_wheel_front_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/right_wheel_front_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_front_joint" type="continuous">
    <parent link="base_link" />
    <child  link="right_wheel_front_link" />
    <origin xyz="0.104 -0.004 -0.167" rpy="0 0 0" />
    <axis xyz="1 0 0" />
  </joint>

  <link name="right_wheel_rear_link">
    <inertial>
      <origin xyz="-0.0097088 -0.00054882 -0.00049453" rpy="0 0 0" />
      <mass value="0.82615" />
      <inertia ixx="0.0051911" ixy="7.6491E-07" ixz="7.2952E-07"
               iyy="0.0028213" iyz="1.2600E-06" izz="0.0028217" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/right_wheel_rear_link.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/right_wheel_rear_link.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="right_wheel_rear_joint" type="continuous">
    <parent link="base_link" />
    <child  link="right_wheel_rear_link" />
    <origin xyz="0.104 -0.004 0.169" rpy="0 0 0" />
    <axis xyz="1 0 0" />
  </joint>

  <link name="base_scan">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0" />
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/base_scan.STL" />
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="package://sim_env/urdf/my_car/meshes/base_scan.STL" />
      </geometry>
    </collision>
  </link>

  <joint name="base_scan_joint" type="fixed">
    <parent link="base_footprint" />
    <child  link="base_scan" />
    <origin xyz="-0.076 0.00074 0.2375" rpy="0 0 0" />
  </joint>

  <gazebo>
    <static>true</static>
  </gazebo>

  <gazebo reference="base_scan">
    <sensor type="ray" name="lds_lfcd_sensor">
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>6.28319</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.120</min>
          <max>10.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lds_lfcd_controller" filename="libgazebo_ros_laser.so">
        <topicName>scan</topicName>
        <frameName>base_scan</frameName>
      </plugin>
    </sensor>
  </gazebo>
</robot>
